# ============================================================
# Vercel Blob Storage
# Get this from: Vercel Dashboard → Storage → Blob → .env.local
# ============================================================
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXX

# ============================================================
# Access Control
# Comma-separated list of valid access keys (no spaces)
# Example: AUTHORIZED_USERS=key-alpha,key-beta,key-gamma
# ============================================================
AUTHORIZED_USERS=admin-key-123,manager-key-456
